{{define "base"}}
<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <link rel="stylesheet" href="/static/css/main.css">
        <title>{{template "title" .}} - Pedro</title>
    </head>
    <body class="app">
        <header class="site-header">
            <div class="container site-header__inner">
                <h1 class="site-logo">
                    <a class="site-logo__link" href="/">Pedro</a>
                </h1>
            </div>
        </header>
    
        <main class="site-main">
            <div class="container">
                {{template "main" .}}
            </div>
        </main>
    </body>
</html>
{{end}}