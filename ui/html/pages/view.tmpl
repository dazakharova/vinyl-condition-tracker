{{define "title"}}Record{{end}}

{{define "main"}}
<section class="page page-record-view">
    {{with .Record}}
    <article class="card record-detail">
        <div class="record-detail__header">
            <div class="record-detail__identity">
                <p class="page-eyebrow">Record</p>
                <h2 class="record-detail__title">{{.Title}}</h2>
                <p class="record-detail__artist">{{.Artist}}</p>
            </div>
        </div>

        <div class="record-meta">
            <div class="record-meta__item">
                <span class="record-meta__label">Created</span>
                <time class="record-meta__value">{{humanDate .CreatedAt}}</time>
            </div>
            <div class="record-meta__item">
                <span class="record-meta__label">Last updated</span>
                <time class="record-meta__value">{{humanDate .UpdatedAt}}</time>
            </div>
        </div>
    </article>
    {{end}}

    <section class="card sides-card">
        <div class="section-header">
            <h3 class="section-title">Sides</h3>
        </div>

        <ul class="side-list">
            {{range .Sides}}
            <li class="side-list__item">
                <span class="side-badge">Side {{.Name}}</span>
            </li>
            {{end}}
        </ul>
    </section>
</section>
{{end}}